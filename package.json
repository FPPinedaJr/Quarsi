{
  "dependencies": {
    "tailwind": "^4.0.0",
    "tailwindcss": "^3.4.9"
  },
  "scripts": {
    "build:admin": "tailwindcss -i ./public/admin/css/input.css -o ./public/admin/css/output.css --watch",
    "build:officer": "tailwindcss -i ./public/officer/css/input.css -o ./public/officer/css/output.css --watch",
    "build:student": "tailwindcss -i ./public/student/css/input.css -o ./public/student/css/output.css --watch",
    "build:sign_in": "tailwindcss -i ./public/sign_in/css/input.css -o ./public/sign_in/css/output.css --watch",
    "build:global": "tailwindcss -i ./public/__assets__/css/input.css -o ./public/__assets__/css/output.css --watch",
    "dev": "npm-run-all --parallel build:*"
  }
}
